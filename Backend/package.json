{
  "name": "stellar-1-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/sensible": "6.0.4",
    "@stellar/stellar-sdk": "14.5.0",
    "dotenv": "17.3.1",
    "drizzle-orm": "0.45.1",
    "fastify": "5.8.3",
    "fastify-plugin": "5.1.0",
    "jsonwebtoken": "9.0.3",
    "postgres": "3.4.8",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.5.2",
    "drizzle-kit": "0.31.4",
    "tsx": "4.20.3",
    "typescript": "5.8.3"
  }
}
